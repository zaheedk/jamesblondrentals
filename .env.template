# Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env files to version control

# Supabase Configuration
# You can find these in your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# RCM API Configuration (Rental Car Manager)
# Contact your RCM provider for these credentials
VITE_RCM_API_KEY=your-rcm-api-key
VITE_RCM_API_SECRET=your-rcm-api-secret

# WhatsApp Business API Configuration
# Get these from Meta Business Manager
VITE_WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
VITE_WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token

# Security Notes:
# - Never expose these values in client-side code
# - Use different values for development and production
# - Regularly rotate API keys and tokens
# - Monitor usage to detect unauthorized access