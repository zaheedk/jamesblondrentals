
{
  "rewrites": [
    {
      "source": "/api/rcm/:path*",
      "destination": "https://apis.rentalcarmanager.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/rcm/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Accept", "value": "application/json" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    }
  ]
}
